{
  "expo": {
    "name": "OrderMe",
    "slug": "mobile",
    "scheme": "orderme",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#1a56db",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orderme.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a56db"
      },
      "package": "com.orderme.app"
    },
    "web": {
      "bundler": "metro",
      "backgroundColor": "#f0f4ff"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow OrderMe to use your location to find nearby services."
        }
      ]
    ]
  }
}
